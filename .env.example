DEMO_MODE=true
INTERNAL_REPLAY_TOKEN=replace-with-a-random-local-token
MCP_SUBMISSION_TOKEN=replace-with-a-second-random-local-token
DATABASE_URL=sqlite:////data/slo-guardian.db
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
JAEGER_QUERY_URL=http://jaeger:16686
GATEWAY_URL=http://gateway:8000
CHECKOUT_URL=http://checkout:8000
INVENTORY_URL=http://inventory:8000
PRICING_URL=http://pricing:8000
RECOMMENDATIONS_URL=http://recommendations:8000
SCENARIOS_DIR=/app/scenarios
FAULT_LATENCY_MS=0
FAULT_ERROR_RATE=0
FAULT_SEED=slo-guardian
ALLOW_SCENARIO_OVERRIDES=true
